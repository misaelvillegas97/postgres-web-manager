# Environment variables for PgStudio Gateway API
# Copy this file to .env and fill in the values.
# In development, DATABASE_URL and CREDENTIALS_ENCRYPTION_KEY are optional.
# In production (NODE_ENV=production), they are required.

PORT=3000
NODE_ENV=development

# PostgreSQL connection string for the internal gateway database
# (NOT for user-managed databases — those are stored in connection_profiles)
DATABASE_URL=postgresql://pgstudio:pgstudio@localhost:5432/pgstudio

# 32+ character key used to encrypt saved connection passwords (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=change_me_to_a_32_plus_char_secret_key_here

# JWT secrets — required in production
JWT_SECRET=change_me_jwt_secret_at_least_32_characters
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_at_least_32_characters

# Resend email delivery for OTP confirmation and password reset
MAIL_FROM=no-reply@example.com
RESEND_API_KEY=re_replace_with_resend_api_key

# CORS allowed origin(s) — use specific origin in production
CORS_ORIGIN=*
