app = "pgstudio"
primary_region = "mad"

[build]
  dockerfile = "docker/all-in-one.Dockerfile"

[env]
  NODE_ENV = "production"
  API_PORT = "3000"
  CORS_ORIGIN = "https://pgstudio.fly.dev"

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = "stop"
  auto_start_machines = true
  min_machines_running = 1
  processes = ["app"]

  [[http_service.checks]]
    interval = "15s"
    timeout = "5s"
    grace_period = "30s"
    method = "GET"
    path = "/api/health"

[[vm]]
  cpu_kind = "shared"
  cpus = 1
  memory_mb = 1024
