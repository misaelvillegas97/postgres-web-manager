{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "docker/all-in-one.Dockerfile",
    "watchPatterns": [
      "apps/api/**",
      "apps/web/**",
      "libs/contracts/**",
      "docker/**",
      "package.json",
      "package-lock.json",
      "nx.json",
      "tsconfig.json",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
