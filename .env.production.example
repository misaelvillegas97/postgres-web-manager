# PgStudio production environment example.
# Copy to .env.production and replace every generated secret before deployment.

PGSTUDIO_WEB_PORT=8080

# Internal PostgreSQL metadata DB used by docker/docker-compose.yml.
# This is not the target database managed through PgStudio; it stores PgStudio users,
# connection profiles, audit logs and query history.
PGSTUDIO_DB_USER=pgstudio
PGSTUDIO_DB_PASSWORD=replace-with-a-strong-random-password
PGSTUDIO_DB_NAME=pgstudio
DATABASE_URL=postgresql://pgstudio:replace-with-a-strong-random-password@postgres:5432/pgstudio

# API runtime.
NODE_ENV=production
CORS_ORIGIN=http://localhost:8080
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-32-random-characters
CREDENTIALS_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
MAIL_FROM=no-reply@example.com
RESEND_API_KEY=re_replace_with_resend_api_key
